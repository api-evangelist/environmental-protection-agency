        },
        {
          "info": {
            "name": "Daily UV index forecast for a city and state",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://data.epa.gov/dmapservice/getEnvirofactsUVDAILY/CITY/:city/STATE/:state/:format",
            "params": [
              {
                "name": "city",
                "value": "",
